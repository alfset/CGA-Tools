# Cardano network: mainnet or preprod
CARDANO_NETWORK=mainnet

# Governance provider: blockfrost or koios
GOVERNANCE_PROVIDER=blockfrost

# Blockfrost config
# Mainnet: https://cardano-mainnet.blockfrost.io/api/v0
# Preprod: https://cardano-preprod.blockfrost.io/api/v0
# Preview: https://cardano-preview.blockfrost.io/api/v0
BLOCKFROST_BASE_URL=
BLOCKFROST_PROJECT_ID=

# Backward-compatible alias for project id (optional)
BLOCKFROST_API_KEY=

# Optional tuning for Blockfrost fetch
BLOCKFROST_MAX_PAGES=20
BLOCKFROST_PAGE_SIZE=100
BLOCKFROST_VOTE_CONCURRENCY=4
BLOCKFROST_PROPOSAL_VOTE_FETCH_LIMIT=120
GOVERNANCE_FETCH_RETRIES=2
GOVERNANCE_RETRY_DELAY_MS=350

# Koios fallback config if GOVERNANCE_PROVIDER=koios
KOIOS_BASE_URL=https://api.koios.rest
KOIOS_PROPOSALS_PATH=/api/v1/proposal_list
KOIOS_VOTES_PATH=/api/v1/proposal_votes

# GitHub scraper config
GITHUB_SCRAPER_ENABLED=1
# Optional token for higher rate limit
GITHUB_TOKEN=

# Proposal evidence scraper config (IPFS / URL KPI & milestone extraction)
PROPOSAL_EVIDENCE_ENABLED=1
PROPOSAL_EVIDENCE_TIMEOUT_MS=15000
PROPOSAL_EVIDENCE_FETCH_LIMIT=80
PROPOSAL_EVIDENCE_CONCURRENCY=6
PROPOSAL_EVIDENCE_MAX_BODY_CHARS=300000
PROPOSAL_EVIDENCE_MAX_ITEMS=12
IPFS_GATEWAY=https://ipfs.io

# Scraper interval in milliseconds
SCRAPER_INTERVAL_MS=300000

# Max age before API auto-refresh analytics
ANALYTICS_MAX_AGE_MS=600000

# Protect cron endpoint
CRON_SECRET=change-me
